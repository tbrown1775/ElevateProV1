# Environment examples for Elevate Pro V1
# Copy one of the stage files below into a real .env file before running commands.

# .env.dev -> local development database
# .env.preview -> preview database
# .env.prod -> production database

# Required in each file:
# NEXT_PUBLIC_APP_ENV=dev|preview|prod
# DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"